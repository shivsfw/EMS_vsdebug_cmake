{
  // ---- CMake Tools: drive everything from CMakePresets.json ----
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,

  // ---- IntelliSense: feed it the exact compiler flags CMake used ----
  // compile_commands.json is emitted by CMAKE_EXPORT_COMPILE_COMMANDS in the root CMakeLists.
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build/Debug/compile_commands.json",
  "C_Cpp.default.compilerPath": "C:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gcc.exe",
  "C_Cpp.default.intelliSenseMode": "gcc-arm",

  // ---- Cortex-Debug: where the ARM GDB + toolchain live ----
  "cortex-debug.armToolchainPath": "C:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin",
  "cortex-debug.gdbPath": "C:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",

  // Quality-of-life
  "files.associations": {
    "*.h": "c",
    "*.ld": "linkerscript"
  }
}
